APP_ENV=local
APP_NAME=zhongmei-rag
JWT_SECRET=change-me-at-least-32-characters-long
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
LOGIN_FAILED_LIMIT=5
LOGIN_FAILED_WINDOW_SECONDS=900
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=Admin@123456
ADMIN_SEED_DISPLAY_NAME=系统管理员
USER_SEED_USERNAME=user
USER_SEED_PASSWORD=User@123456
USER_SEED_DISPLAY_NAME=普通用户
DEFAULT_USERS_RESET_PASSWORDS=false
REDIS_URL=redis://redis:6379/0
DATABASE_URL=mysql+asyncmy://root:zhongmei-root@seekdb:2881/zhongmei?charset=utf8mb4
SEEKDB_IMAGE=docker.1ms.run/oceanbase/seekdb:latest
SEEKDB_PORT=12881
SEEKDB_DASHBOARD_PORT=12886
SEEKDB_ROOT_PASSWORD=zhongmei-root
SEEKDB_DATABASE=zhongmei
API_PORT=8000
NGINX_PORT=8080
FLOWER_PORT=5555
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
VITE_API_BASE_URL=/api/v2
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_NATIVE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_CHAT_MODEL=qwen3.6-plus
DASHSCOPE_CHAT_MODEL_FALLBACK=qwen3-turbo
DASHSCOPE_CHAT_ENABLE_THINKING=false
DASHSCOPE_EMBEDDING_MODEL=qwen3-vl-embedding
DASHSCOPE_EMBEDDING_DIMENSION=1024
CHAT_HISTORY_LIMIT=50
CHAT_MIN_SCORE_THRESHOLD=0.05
CHAT_TOPK=6
CHAT_NO_HIT_MESSAGE=无法在知识库中找到依据，建议换个问法或先上传相关文档。
OCR_WORKSTATION_HOST=222.195.4.65
OCR_BASE_URL=http://222.195.4.65:8899
OCR_CALLBACK_BASE_URL=http://127.0.0.1:18000
OCR_CALLBACK_TOKEN=
OCR_POLL_INTERVAL_SECONDS=5
OCR_MAX_POLL_MINUTES=60
UPLOAD_DIR=uploads/documents
UPLOAD_MAX_MB=200
UPLOAD_MAX_FILES=50
EMBED_BATCH_SIZE=25
CHUNK_TOKENS=512
CHUNK_OVERLAP=64
